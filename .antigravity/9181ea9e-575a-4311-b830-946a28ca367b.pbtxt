  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \'react\';\nimport { \n  EMISSION_FACTORS, \n  INITIAL_STATE, \n  calculateTotalCO2, \n  saveToLocalStorage, \n  loadFromLocalStorage \n} from \'./store.js\';\nimport { \n  Car, \n  Train, \n  Beef, \n  Leaf, \n  Zap, \n  Save, \n  RefreshCw, \n  Check, \n  Code, \n  Calculator,\n  HardDrive,\n  ExternalLink,\n  ChevronRight,\n  Info\n} from \'lucide-react\';\nimport { motion, AnimatePresence } from \'motion/react\';\n\nexport default function App() {\n  // 1. Lokalen Zustand mit Werten aus dem LocalStorage initialisieren oder auf Standard zur\303\274ckgreifen\n  const [state, setState] = useState(() => {\n    return loadFromLocalStorage();\n  });\n\n  // 2. Zustand f\303\274r Benachrichtigungen und UI-Interaktionen\n  const [saveSuccess, setSaveSuccess] = useState(false);\n  const [activeTab, setActiveTab] = useState<\'calculator\' | \'code\'>(\'calculator\');\n  const [copied, setCopied] = useState(false);\n\n  // 3. Berechneten Wert live ermitteln\n  const totalCO2 = calculateTotalCO2(state);\n\n  // 4. Manuelles Speichern mit visuellem Feedback\n  const handleSave = () => {\n    const success = saveToLocalStorage(state);\n    if (success) {\n      setSaveSuccess(true);\n      setTimeout(() => setSaveSuccess(false), 2000);\n    }\n  };\n\n  // Auto-Save bei Parameter\303\244nderungen f\303\274r bessere UX\n  useEffect(() => {\n    saveToLocalStorage(state);\n  }, [state]);\n\n  // Funktion zum Zur\303\274cksetzen auf die Standardwerte\n  const handleReset = () => {\n    setState(JSON.parse(JSON.stringify(INITIAL_STATE)));\n  };\n\n  // Handler f\303\274r numerische Eingaben (verhindert negative Werte)\n  const updateValue = (category: string, field: string, value: number) => {\n    const cleanValue = Math.max(0, isNaN(value) ? 0 : value);\n    setState((prev: any) => ({\n      ...prev,\n      [category]: {\n        ...prev[category],\n        [field]: cleanValue\n      }\n    }));\n  };\n\n  // Code-String f\303\274r den einfachen Export\n  const storeCode = `/**\n * @file store.js\n * @description Kernlogik und Datenstruktur f\303\274r den Alltags-CO2-Rechner.\n * Enth\303\244lt die Emissionsfaktoren, den initialen Anwendungsstatus sowie\n * Berechnungs- und Persistierungsfunktionen f\303\274r den Browser (ES6-Module).\n */\n\nexport const EMISSION_FACTORS = {\n  transport: {\n    car: 0.12,            // Auto: 0.12kg CO2 pro km\n    publicTransport: 0.03 // \303\226PNV: 0.03kg CO2 pro km\n  },\n  diet: {\n    meatRich: 2.5,        // Fleischreich: 2.5kg CO2 pro Tag\n    vegan: 0.9            // Vegan: 0.9kg CO2 pro Tag\n  },\n  consumption: {\n    electricity: 0.42     // Stromverbrauch pro kWh: 0.42kg CO2\n  }\n};\n\nexport const INITIAL_STATE = {\n  transport: {\n    carKm: 0,              // Gefahrene Kilometer mit dem Auto\n    publicTransportKm: 0   // Zur\303\274ckgelegte Kilometer im \303\226PNV\n  },\n  diet: {\n    meatRichDays: 0,       // Tage mit fleischreicher Ern\303\244hrung\n    veganDays: 0           // Tage mit veganer Ern\303\244hrung\n  },\n  consumption: {\n    electricityKWh: 0      // Stromverbrauch in kWh\n  }\n};\n\nexport function calculateTotalCO2(state) {\n  if (!state) return 0;\n\n  const carCO2 = (state.transport?.carKm || 0) * EMISSION_FACTORS.transport.car;\n  const publicTransportCO2 = (state.transport?.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport;\n  const transportTotal = carCO2 + publicTransportCO2;\n\n  const meatRichCO2 = (state.diet?.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich;\n  const veganCO2 = (state.diet?.veganDays || 0) * EMISSION_FACTORS.diet.vegan;\n  const dietTotal = meatRichCO2 + veganCO2;\n\n  const electricityCO2 = (state.consumption?.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity;\n\n  const total = transportTotal + dietTotal + electricityCO2;\n  return Math.round(total * 100) / 100;\n}\n\nexport function saveToLocalStorage(state, key = \'co2_calculator_state\') {\n  try {\n    localStorage.setItem(key, JSON.stringify(state));\n    return true;\n  } catch (error) {\n    console.error(\'Fehler beim Speichern:\', error);\n    return false;\n  }\n}\n\nexport function loadFromLocalStorage(key = \'co2_calculator_state\') {\n  try {\n    const serializedState = localStorage.getItem(key);\n    if (!serializedState) return JSON.parse(JSON.stringify(INITIAL_STATE));\n    const loaded = JSON.parse(serializedState);\n    return {\n      transport: {\n        carKm: typeof loaded?.transport?.carKm === \'number\' ? loaded.transport.carKm : INITIAL_STATE.transport.carKm,\n        publicTransportKm: typeof loaded?.transport?.publicTransportKm === \'number\' ? loaded.transport.publicTransportKm : INITIAL_STATE.transport.publicTransportKm\n      },\n      diet: {\n        meatRichDays: typeof loaded?.diet?.meatRichDays === \'number\' ? loaded.diet.meatRichDays : INITIAL_STATE.diet.meatRichDays,\n        veganDays: typeof loaded?.diet?.veganDays === \'number\' ? loaded.diet.veganDays : INITIAL_STATE.diet.veganDays\n      },\n      consumption: {\n        electricityKWh: typeof loaded?.consumption?.electricityKWh === \'number\' ? loaded.consumption.electricityKWh : INITIAL_STATE.consumption.electricityKWh\n      }\n    };\n  } catch (error) {\n    return JSON.parse(JSON.stringify(INITIAL_STATE));\n  }\n}`;\n\n  const copyToClipboard = () => {\n    navigator.clipboard.writeText(storeCode);\n    setCopied(true);\n    setTimeout(() => setCopied(false), 2000);\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col antialiased\">\n      {/* 1. Header Segment */}\n      <header className=\"bg-white border-b border-slate-200 sticky top-0 z-10 px-6 py-4 shadow-xs\">\n        <div className=\"max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"px-2 py-0.5 bg-emerald-100 text-emerald-800 text-xs font-semibold rounded-full uppercase tracking-wider\">\n                Schnittstellen-Prototyp\n              </span>\n              <span className=\"text-xs text-slate-400 font-mono\">store.js v1.0.0</span>\n            </div>\n            <h1 className=\"text-xl font-bold tracking-tight text-slate-900 mt-1 flex items-center gap-2\">\n              Alltags-CO2-Rechner <span className=\"text-emerald-600 font-mono\">\302\267</span> Kernlogik\n            </h1>\n          </div>\n          \n          {/* Navigation Tabs */}\n          <div className=\"flex bg-slate-100 rounded-lg p-1 text-sm self-start sm:self-auto shadow-inner\">\n            <button\n              onClick={() => setActiveTab(\'calculator\')}\n              className={`flex items-center gap-2 px-4 py-2 rounded-md transition-all font-medium ${\n                activeTab === \'calculator\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-500 hover:text-slate-900\'\n              }`}\n            >\n              <Calculator size={16} />\n              Interaktive Vorschau\n            </button>\n            <button\n              onClick={() => setActiveTab(\'code\')}\n              className={`flex items-center gap-2 px-4 py-2 rounded-md transition-all font-medium ${\n                activeTab === \'code\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-500 hover:text-slate-900\'\n              }`}\n            >\n              <Code size={16} />\n              Code ansehen (store.js)\n            </button>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Sandbox Area */}\n      <main className=\"flex-1 max-w-6xl mx-auto w-full px-6 py-8\">\n        \n        {/* Info alert about statelessness & clean ES6 specifications */}\n        <div className=\"mb-6 p-4 bg-blue-50/80 border border-blue-200 rounded-xl text-sm text-slate-700 flex gap-3 shadow-xs\">\n          <Info className=\"text-blue-500 flex-shrink-0 mt-0.5\" size={18} />\n          <div>\n            <p className=\"font-semibold text-blue-900\">Plattformunabh\303\244ngige Kernlogik</p>\n            <p className=\"mt-0.5 text-blue-800\">\n              Dieser Prototyp l\303\244uft vollst\303\244ndig clientseitig im Browser \303\274ber ES6-Module. Er nutzt das \n              definierte Anwendungs-Statusobjekt und berechnet alle Werte in Echtzeit. \303\204nderungen werden automatisch im <code className=\"bg-blue-100 px-1 py-0.5 rounded font-mono text-xs font-semibold\">localStorage</code> persistiert.\n            </p>\n          </div>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {activeTab === \'calculator\' ? (\n            <motion.div\n              key=\"calc\"\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n              className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\"\n            >\n              \n              {/* Left & Middle Column: Interactive Input Modules */}\n              <div className=\"lg:col-span-2 space-y-6\">\n                \n                {/* 1. Category: Transport */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-blue-100 text-blue-700 rounded-lg\">\n                        <Car size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">1. Transport</h2>\n                        <p className=\"text-xs text-slate-500\">Minderungsfaktor durch \303\226PNV-Fokus</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6 space-y-5\">\n                    \n                    {/* Car km input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          Autonutzung\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.transport.car} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.transport.carKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'carKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          km\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>Zuletzt gefahrene Distanz</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                    <div className=\"border-t border-slate-100 pt-4\" />\n\n                    {/* Public transport input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          \303\226PNV-Nutzung (Bus & Bahn)\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.transport.publicTransport} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.transport.publicTransportKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'publicTransportKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          km\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>Zur\303\274ckgelegte Distanz \303\226PNV</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 2. Category: Nutrition */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-emerald-100 text-emerald-700 rounded-lg\">\n                        <Leaf size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">2. Ern\303\244hrung</h2>\n                        <p className=\"text-xs text-slate-500\">Tagesbilanzierung unterschiedlicher Ern\303\244hrungsstile</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6 space-y-5\">\n                    \n                    {/* Meat-rich days */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          <Beef size={15} className=\"text-red-500\" />\n                          Fleischreiche Tage\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.diet.meatRich} kg CO\342\202\202 / Tag\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.diet.meatRichDays || \'\'}\n                          onChange={(e) => updateValue(\'diet\', \'meatRichDays\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-sans\">\n                          Tage\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>CO\342\202\202-Last durch fleischreiche Kost</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                    <div className=\"border-t border-slate-100 pt-4\" />\n\n                    {/* Vegan days */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          <Leaf size={15} className=\"text-emerald-500\" />\n                          Vegane Tage\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.diet.vegan} kg CO\342\202\202 / Tag\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.diet.veganDays || \'\'}\n                          onChange={(e) => updateValue(\'diet\', \'veganDays\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm\">\n                          Tage\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>CO\342\202\202-Last durch vegane Tage</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 3. Category: Consumption (Electricity) */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-amber-100 text-amber-700 rounded-lg\">\n                        <Zap size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">3. Konsum (Strom)</h2>\n                        <p className=\"text-xs text-slate-500\">Stromverbrauch auf Basis der aktuellen kWh-Menge</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6\">\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          Stromverbrauch\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.consumption.electricity} kg CO\342\202\202 / kWh\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.consumption.electricityKWh || \'\'}\n                          onChange={(e) => updateValue(\'consumption\', \'electricityKWh\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          kWh\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 mt-2 px-1\">\n                        <span>Stromverbrauch gesamt</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n\n              {/* Right Column: Calculations Center + Statistics summary */}\n              <div className=\"space-y-6\">\n                \n                {/* Visualizer / Output Panel Card */}\n                <div className=\"bg-slate-900 text-white rounded-2xl p-6 border border-slate-800 shadow-xl flex flex-col justify-between min-h-[380px] sticky top-24\">\n                  <div>\n                    <span className=\"text-emerald-400 font-mono text-xs uppercase tracking-wider font-semibold\">\n                      LOGIK-BERECHNUNGSZENTRALE\n                    </span>\n                    <h3 className=\"text-lg font-bold text-slate-150 mt-1\">Echtzeit-Emissionen</h3>\n                    <p className=\"text-xs text-slate-400 mt-2\">\n                      Anwendung der Berechnungsformel <code className=\"text-slate-300 bg-slate-800 px-1 py-0.5 rounded font-mono\">calculateTotalCO2()</code> im ES6-Store.\n                    </p>\n                    \n                    {/* Big Metric Display */}\n                    <div className=\"my-8 py-5 border-y border-slate-800 flex flex-col items-center\">\n                      <span className=\"text-slate-400 text-sm\">Berechnetes CO\342\202\202-\303\204quivalent</span>\n                      <div className=\"flex items-baseline gap-2 mt-1\">\n                        <motion.span \n                          key={totalCO2}\n                          initial={{ scale: 0.95, opacity: 0.8 }}\n                          animate={{ scale: 1, opacity: 1 }}\n                          className=\"text-5xl font-extrabold tracking-tight text-emerald-400 font-mono\"\n                        >\n                          {totalCO2.toLocaleString(\'de-DE\', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}\n                        </motion.span>\n                        <span className=\"text-xl text-slate-300 font-semibold font-sans\">kg</span>\n                      </div>\n                    </div>\n\n                    {/* Breakdown micro tables */}\n                    <div className=\"space-y-2 mt-4 text-xs font-mono text-slate-300\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Transport:</span>\n                        <span>\n                          {(((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car) +\n                            ((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Ern\303\244hrung:</span>\n                        <span>\n                          {(((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich) + \n                            ((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Konsum:</span>\n                        <span>\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-3 mt-8\">\n                    {/* Action buttons testing states */}\n                    <button\n                      onClick={handleSave}\n                      className=\"w-full py-3 px-4 bg-emerald-600 hover:bg-emerald-500 rounded-xl font-semibold text-sm transition-all focus:outline-hidden focus:ring-2 focus:ring-emerald-400 flex items-center justify-center gap-2 cursor-pointer shadow-md shadow-emerald-900/20 active:scale-[0.98]\"\n                    >\n                      {saveSuccess ? (\n                        <>\n                          <Check size={16} className=\"text-white\" />\n                          Gespeichert!\n                        </>\n                      ) : (\n                        <>\n                          <Save size={16} />\n                          Zustand manuell persistieren\n                        </>\n                      )}\n                    </button>\n\n                    <button\n                      onClick={handleReset}\n                      className=\"w-full py-3 px-4 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl font-medium text-slate-300 hover:text-white text-sm transition-all flex items-center justify-center gap-2 cursor-pointer\"\n                    >\n                      <RefreshCw size={14} />\n                      Werte zur\303\274cksetzen (Reset)\n                    </button>\n                    \n                    <div className=\"flex justify-center items-center gap-1.5 text-[11px] text-slate-500 font-mono bg-slate-950/40 py-2 rounded-lg\">\n                      <HardDrive size={12} />\n                      Wird bei \303\204nderungen automatisch gespeichert\n                    </div>\n                  </div>\n\n                </div>\n\n              </div>\n\n            </motion.div>\n          ) : (\n            \n            /* Code View Tab showing modular layout specifications */\n            <motion.div\n              key=\"code\"\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n              className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden\"\n            >\n              <div className=\"bg-slate-900 text-slate-400 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"w-3 h-3 rounded-full bg-red-500\" />\n                  <div className=\"w-3 h-3 rounded-full bg-amber-500\" />\n                  <div className=\"w-3 h-3 rounded-full bg-emerald-500\" />\n                  <span className=\"text-xs text-slate-400 font-mono ml-3\">/src/store.js</span>\n                </div>\n                \n                <button\n                  onClick={copyToClipboard}\n                  className=\"px-3 py-1.5 bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs font-semibold rounded-md border border-slate-700 transition-all flex items-center gap-2 active:scale-95\"\n                >\n                  {copied ? (\n                    <>\n                      <Check size={13} className=\"text-emerald-400\" />\n                      Kopiert!\n                    </>\n                  ) : (\n                    <>\n                      Kopieren\n                    </>\n                  )}\n                </button>\n              </div>\n              \n              <div className=\"p-6 bg-slate-950 overflow-x-auto text-xs font-mono text-emerald-300 leading-relaxed shadow-inner\">\n                <pre>{storeCode}</pre>\n              </div>\n\n              <div className=\"bg-slate-50 p-6 border-t border-slate-200 text-sm text-slate-700 space-y-3\">\n                <h4 className=\"font-bold text-slate-900 flex items-center gap-1.5\">\n                  <Sparkles size={16} className=\"text-emerald-600\" />\n                  Architekturmerkmale dieser L\303\266sung:\n                </h4>\n                <ul className=\"list-disc pl-5 space-y-1 text-slate-600\">\n                  <li><strong>Saubere Separation of Concerns</strong>: Die gesamte Kalkulationslogik liegt losgel\303\266st von irgendwelchem Markup oder Styling in <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">store.js</code>.</li>\n                  <li><strong>Deep Clone Safety</strong>: Beim Laden/Standardisieren wird mit <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">JSON.parse(JSON.stringify())</code> gearbeitet, um versehentliche Mutationen von <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">INITIAL_STATE</code> zu verhindern.</li>\n                  <li><strong>Eingabe-Ausfallsicherheit</strong>: Das Modell f\303\244ngt fehlerhafte/unvollst\303\244ndige Typen im <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">localStorage</code> automatisch ab und synchronisiert die Struktur.</li>\n                </ul>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n      </main>\n\n      {/* Light Clean Footer */}\n      <footer className=\"bg-white border-t border-slate-200 py-6 px-6 text-center text-xs text-slate-400 mt-auto\">\n        <p>\302\251 2026 Alltags-CO2-Rechner. Entwickelt als plattformunabh\303\244ngige ESM-Kernarchitektur.</p>\n      </footer>\n    </div>\n  );\n}\n"
    }
