      original_chunk {
        target_content: "  return (\n    <div className=\"min-h-screen bg-slate-50 text-slate-800 font-sans flex flex-col antialiased\">\n      {/* 1. Header Segment */}\n      <header className=\"bg-white border-b border-slate-200 sticky top-0 z-10 px-6 py-4 shadow-xs\">\n        <div className=\"max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4\">\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"px-2 py-0.5 bg-emerald-100 text-emerald-800 text-xs font-semibold rounded-full uppercase tracking-wider\">\n                Schnittstellen-Prototyp\n              </span>\n              <span className=\"text-xs text-slate-400 font-mono\">store.js v1.0.0</span>\n            </div>\n            <h1 className=\"text-xl font-bold tracking-tight text-slate-900 mt-1 flex items-center gap-2\">\n              Alltags-CO2-Rechner <span className=\"text-emerald-600 font-mono\">\302\267</span> Kernlogik\n            </h1>\n          </div>\n          \n          {/* Navigation Tabs */}\n          <div className=\"flex bg-slate-100 rounded-lg p-1 text-sm self-start sm:self-auto shadow-inner\">\n            <button\n              onClick={() => setActiveTab(\'calculator\')}\n              className={`flex items-center gap-2 px-4 py-2 rounded-md transition-all font-medium ${\n                activeTab === \'calculator\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-500 hover:text-slate-900\'\n              }`}\n            >\n              <Calculator size={16} />\n              Interaktive Vorschau\n            </button>\n            <button\n              onClick={() => setActiveTab(\'code\')}\n              className={`flex items-center gap-2 px-4 py-2 rounded-md transition-all font-medium ${\n                activeTab === \'code\'\n                  ? \'bg-white text-slate-900 shadow-sm\'\n                  : \'text-slate-500 hover:text-slate-900\'\n              }`}\n            >\n              <Code size={16} />\n              Code ansehen (store.js)\n            </button>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Sandbox Area */}\n      <main className=\"flex-1 max-w-6xl mx-auto w-full px-6 py-8\">\n        \n        {/* Info alert about statelessness & clean ES6 specifications */}\n        <div className=\"mb-6 p-4 bg-blue-50/80 border border-blue-200 rounded-xl text-sm text-slate-700 flex gap-3 shadow-xs\">\n          <Info className=\"text-blue-500 flex-shrink-0 mt-0.5\" size={18} />\n          <div>\n            <p className=\"font-semibold text-blue-900\">Plattformunabh\303\244ngige Kernlogik</p>\n            <p className=\"mt-0.5 text-blue-800\">\n              Dieser Prototyp l\303\244uft vollst\303\244ndig clientseitig im Browser \303\274ber ES6-Module. Er nutzt das \n              definierte Anwendungs-Statusobjekt und berechnet alle Werte in Echtzeit. \303\204nderungen werden automatisch im <code className=\"bg-blue-100 px-1 py-0.5 rounded font-mono text-xs font-semibold\">localStorage</code> persistiert.\n            </p>\n          </div>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {activeTab === \'calculator\' ? (\n            <motion.div\n              key=\"calc\"\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n              className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\"\n            >\n              \n              {/* Left & Middle Column: Interactive Input Modules */}\n              <div className=\"lg:col-span-2 space-y-6\">\n                \n                {/* 1. Category: Transport */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-blue-100 text-blue-700 rounded-lg\">\n                        <Car size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">1. Transport</h2>\n                        <p className=\"text-xs text-slate-500\">Minderungsfaktor durch \303\226PNV-Fokus</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6 space-y-5\">\n                    \n                    {/* Car km input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          Autonutzung\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.transport.car} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.transport.carKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'carKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          km\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>Zuletzt gefahrene Distanz</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                    <div className=\"border-t border-slate-100 pt-4\" />\n\n                    {/* Public transport input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          \303\226PNV-Nutzung (Bus & Bahn)\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.transport.publicTransport} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.transport.publicTransportKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'publicTransportKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          km\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>Zur\303\274ckgelegte Distanz \303\226PNV</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 2. Category: Nutrition */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-emerald-100 text-emerald-700 rounded-lg\">\n                        <Leaf size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">2. Ern\303\244hrung</h2>\n                        <p className=\"text-xs text-slate-500\">Tagesbilanzierung unterschiedlicher Ern\303\244hrungsstile</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6 space-y-5\">\n                    \n                    {/* Meat-rich days */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          <Beef size={15} className=\"text-red-500\" />\n                          Fleischreiche Tage\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.diet.meatRich} kg CO\342\202\202 / Tag\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.diet.meatRichDays || \'\'}\n                          onChange={(e) => updateValue(\'diet\', \'meatRichDays\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-sans\">\n                          Tage\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>CO\342\202\202-Last durch fleischreiche Kost</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                    <div className=\"border-t border-slate-100 pt-4\" />\n\n                    {/* Vegan days */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          <Leaf size={15} className=\"text-emerald-500\" />\n                          Vegane Tage\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.diet.vegan} kg CO\342\202\202 / Tag\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.diet.veganDays || \'\'}\n                          onChange={(e) => updateValue(\'diet\', \'veganDays\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm\">\n                          Tage\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 px-1\">\n                        <span>CO\342\202\202-Last durch vegane Tage</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 3. Category: Consumption (Electricity) */}\n                <div className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden transition-all hover:shadow-md\">\n                  <header className=\"bg-slate-50 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-amber-100 text-amber-700 rounded-lg\">\n                        <Zap size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"font-bold text-slate-900\">3. Konsum (Strom)</h2>\n                        <p className=\"text-xs text-slate-500\">Stromverbrauch auf Basis der aktuellen kWh-Menge</p>\n                      </div>\n                    </div>\n                  </header>\n                  <div className=\"p-6\">\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-slate-700 flex items-center gap-1.5\">\n                          Stromverbrauch\n                        </label>\n                        <span className=\"text-xs font-mono text-slate-400\">\n                          {EMISSION_FACTORS.consumption.electricity} kg CO\342\202\202 / kWh\n                        </span>\n                      </div>\n                      <div className=\"flex mt-1 rounded-lg shadow-sm\">\n                        <input\n                          type=\"number\"\n                          value={state.consumption.electricityKWh || \'\'}\n                          onChange={(e) => updateValue(\'consumption\', \'electricityKWh\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-2.5 bg-white border border-slate-300 rounded-l-lg focus:outline-hidden focus:ring-2 focus:ring-emerald-500 focus:border-transparent text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 rounded-r-lg border border-l-0 border-slate-300 bg-slate-50 text-slate-500 text-sm font-mono\">\n                          kWh\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-slate-500 mt-2 px-1\">\n                        <span>Stromverbrauch gesamt</span>\n                        <span className=\"font-semibold text-slate-700 font-mono\">\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n\n              {/* Right Column: Calculations Center + Statistics summary */}\n              <div className=\"space-y-6\">\n                \n                {/* Visualizer / Output Panel Card */}\n                <div className=\"bg-slate-900 text-white rounded-2xl p-6 border border-slate-800 shadow-xl flex flex-col justify-between min-h-[380px] sticky top-24\">\n                  <div>\n                    <span className=\"text-emerald-400 font-mono text-xs uppercase tracking-wider font-semibold\">\n                      LOGIK-BERECHNUNGSZENTRALE\n                    </span>\n                    <h3 className=\"text-lg font-bold text-slate-150 mt-1\">Echtzeit-Emissionen</h3>\n                    <p className=\"text-xs text-slate-400 mt-2\">\n                      Anwendung der Berechnungsformel <code className=\"text-slate-300 bg-slate-800 px-1 py-0.5 rounded font-mono\">calculateTotalCO2()</code> im ES6-Store.\n                    </p>\n                    \n                    {/* Big Metric Display */}\n                    <div className=\"my-8 py-5 border-y border-slate-800 flex flex-col items-center\">\n                      <span className=\"text-slate-400 text-sm\">Berechnetes CO\342\202\202-\303\204quivalent</span>\n                      <div className=\"flex items-baseline gap-2 mt-1\">\n                        <motion.span \n                          key={totalCO2}\n                          initial={{ scale: 0.95, opacity: 0.8 }}\n                          animate={{ scale: 1, opacity: 1 }}\n                          className=\"text-5xl font-extrabold tracking-tight text-emerald-400 font-mono\"\n                        >\n                          {totalCO2.toLocaleString(\'de-DE\', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}\n                        </motion.span>\n                        <span className=\"text-xl text-slate-300 font-semibold font-sans\">kg</span>\n                      </div>\n                    </div>\n\n                    {/* Breakdown micro tables */}\n                    <div className=\"space-y-2 mt-4 text-xs font-mono text-slate-300\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Transport:</span>\n                        <span>\n                          {(((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car) +\n                            ((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Ern\303\244hrung:</span>\n                        <span>\n                          {(((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich) + \n                            ((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-slate-400\">Konsum:</span>\n                        <span>\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-3 mt-8\">\n                    {/* Action buttons testing states */}\n                    <button\n                      onClick={handleSave}\n                      className=\"w-full py-3 px-4 bg-emerald-600 hover:bg-emerald-500 rounded-xl font-semibold text-sm transition-all focus:outline-hidden focus:ring-2 focus:ring-emerald-400 flex items-center justify-center gap-2 cursor-pointer shadow-md shadow-emerald-900/20 active:scale-[0.98]\"\n                    >\n                      {saveSuccess ? (\n                        <>\n                          <Check size={16} className=\"text-white\" />\n                          Gespeichert!\n                        </>\n                      ) : (\n                        <>\n                          <Save size={16} />\n                          Zustand manuell persistieren\n                        </>\n                      )}\n                    </button>\n\n                    <button\n                      onClick={handleReset}\n                      className=\"w-full py-3 px-4 bg-slate-800 hover:bg-slate-700 border border-slate-700 rounded-xl font-medium text-slate-300 hover:text-white text-sm transition-all flex items-center justify-center gap-2 cursor-pointer\"\n                    >\n                      <RefreshCw size={14} />\n                      Werte zur\303\274cksetzen (Reset)\n                    </button>\n                    \n                    <div className=\"flex justify-center items-center gap-1.5 text-[11px] text-slate-500 font-mono bg-slate-950/40 py-2 rounded-lg\">\n                      <HardDrive size={12} />\n                      Wird bei \303\204nderungen automatisch gespeichert\n                    </div>\n                  </div>\n\n                </div>\n\n              </div>\n\n            </motion.div>\n          ) : (\n            \n            /* Code View Tab showing modular layout specifications */\n            <motion.div\n              key=\"code\"\n              initial={{ opacity: 0, y: 10 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -10 }}\n              className=\"bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden\"\n            >\n              <div className=\"bg-slate-900 text-slate-400 px-6 py-4 border-b border-slate-200 flex items-center justify-between\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"w-3 h-3 rounded-full bg-red-500\" />\n                  <div className=\"w-3 h-3 rounded-full bg-amber-500\" />\n                  <div className=\"w-3 h-3 rounded-full bg-emerald-500\" />\n                  <span className=\"text-xs text-slate-400 font-mono ml-3\">/src/store.js</span>\n                </div>\n                \n                <button\n                  onClick={copyToClipboard}\n                  className=\"px-3 py-1.5 bg-slate-800 hover:bg-slate-700 text-slate-200 text-xs font-semibold rounded-md border border-slate-700 transition-all flex items-center gap-2 active:scale-95\"\n                >\n                  {copied ? (\n                    <>\n                      <Check size={13} className=\"text-emerald-400\" />\n                      Kopiert!\n                    </>\n                  ) : (\n                    <>\n                      Kopieren\n                    </>\n                  )}\n                </button>\n              </div>\n              \n              <div className=\"p-6 bg-slate-950 overflow-x-auto text-xs font-mono text-emerald-300 leading-relaxed shadow-inner\">\n                <pre>{storeCode}</pre>\n              </div>\n\n              <div className=\"bg-slate-50 p-6 border-t border-slate-200 text-sm text-slate-700 space-y-3\">\n                <h4 className=\"font-bold text-slate-900 flex items-center gap-1.5\">\n                  <Sparkles size={16} className=\"text-emerald-600\" />\n                  Architekturmerkmale dieser L\303\266sung:\n                </h4>\n                <ul className=\"list-disc pl-5 space-y-1 text-slate-600\">\n                  <li><strong>Saubere Separation of Concerns</strong>: Die gesamte Kalkulationslogik liegt losgel\303\266st von irgendwelchem Markup oder Styling in <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">store.js</code>.</li>\n                  <li><strong>Deep Clone Safety</strong>: Beim Laden/Standardisieren wird mit <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">JSON.parse(JSON.stringify())</code> gearbeitet, um versehentliche Mutationen von <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">INITIAL_STATE</code> zu verhindern.</li>\n                  <li><strong>Eingabe-Ausfallsicherheit</strong>: Das Modell f\303\244ngt fehlerhafte/unvollst\303\244ndige Typen im <code className=\"bg-slate-100 text-slate-800 px-1 py-0.5 rounded font-mono text-xs\">localStorage</code> automatisch ab und synchronisiert die Struktur.</li>\n                </ul>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n      </main>\n\n      {/* Light Clean Footer */}\n      <footer className=\"bg-white border-t border-slate-200 py-6 px-6 text-center text-xs text-slate-400 mt-auto\">\n        <p>\302\251 2026 Alltags-CO2-Rechner. Entwickelt als plattformunabh\303\244ngige ESM-Kernarchitektur.</p>\n      </footer>\n    </div>\n  );"
        replacement_content: "  return (\n    <div className=\"min-h-screen bg-natural-bg text-natural-text font-sans flex flex-col antialiased\">\n      {/* 1. Header Segment in Natural Tones theme style */}\n      <header className=\"bg-white/70 backdrop-blur-md border-b border-natural-border sticky top-0 z-20 px-6 py-5 transition-all\">\n        <div className=\"max-w-6xl mx-auto flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6\">\n          <div>\n            <div className=\"flex items-center gap-2\">\n              <span className=\"px-2 py-0.5 bg-natural-sage text-natural-olive text-[10px] font-bold code tracking-wider rounded\">\n                PROTOTYPE V1.0.4 \342\200\224 ES6 ARCHITECTURE\n              </span>\n              <span className=\"text-xs text-slate-400 font-mono\">store.js ES6 Standard</span>\n            </div>\n            <h1 className=\"serif text-4xl sm:text-5xl font-light italic text-natural-text mt-2\">\n              CO2 Architecture\n            </h1>\n          </div>\n          \n          {/* Tabs & Quick Summary Indicator */}\n          <div className=\"flex flex-col sm:items-end gap-3\">\n            {/* Navigation Tabs */}\n            <div className=\"flex bg-natural-sage/50 border border-natural-border/40 rounded-full p-1 text-xs self-start sm:self-auto\">\n              <button\n                id=\"tab-calculator\"\n                onClick={() => setActiveTab(\'calculator\')}\n                className={`flex items-center gap-1.5 px-4 py-1.5 rounded-full transition-all font-medium cursor-pointer ${\n                  activeTab === \'calculator\'\n                    ? \'bg-natural-olive text-natural-bg shadow-xs\'\n                    : \'text-natural-olive hover:text-natural-text\'\n                }`}\n              >\n                <Calculator size={13} />\n                Interaktive Vorschau\n              </button>\n              <button\n                id=\"tab-code\"\n                onClick={() => setActiveTab(\'code\')}\n                className={`flex items-center gap-1.5 px-4 py-1.5 rounded-full transition-all font-medium cursor-pointer ${\n                  activeTab === \'code\'\n                    ? \'bg-natural-olive text-natural-bg shadow-xs\'\n                    : \'text-natural-olive hover:text-natural-text\'\n                }`}\n              >\n                <Code size={13} />\n                Code ansehen (store.js)\n              </button>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Sandbox Area in Natural Tones theme */}\n      <main className=\"flex-1 max-w-6xl mx-auto w-full px-6 py-8\">\n        \n        {/* Natural Tones info warning alert bar */}\n        <div className=\"mb-8 p-5 bg-white rounded-2xl border border-natural-border/30 text-sm text-natural-text flex gap-4 shadow-xs\">\n          <Info className=\"text-natural-olive flex-shrink-0 mt-0.5\" size={20} />\n          <div>\n            <p className=\"font-semibold serif text-xl italic text-natural-olive\">Lokales ES6-Berechnungsmodul</p>\n            <p className=\"mt-1 text-natural-text/80 leading-relaxed\">\n              Dieses System demonstriert die reine Berechnungs- und Speicherlogik f\303\274r einen Alltags-CO2-Rechner. \n              Berechnungen laufen live im Browser ab, und der State wird bei Parameter-Eingaben automatisch persistent im <code className=\"bg-natural-sage/50 px-1 py-0.5 rounded font-mono text-xs font-semibold\">localStorage</code> abgelegt.\n            </p>\n          </div>\n        </div>\n\n        <AnimatePresence mode=\"wait\">\n          {activeTab === \'calculator\' ? (\n            <motion.div\n              key=\"calc\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.25 }}\n              className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\"\n            >\n              \n              {/* Left & Middle Column: Interactive Input Modules */}\n              <div className=\"lg:col-span-2 space-y-6\">\n                \n                {/* 1. Category: Transport */}\n                <div className=\"card-natural p-6 flex flex-col justify-between hover:translate-y-[-1px] transition-all bg-white\">\n                  <header className=\"flex justify-between items-start mb-6 border-b border-natural-border/20 pb-4\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-natural-sage rounded-xl text-natural-olive\">\n                        <Car size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"serif text-2xl text-natural-text\">01. Transport Module</h2>\n                        <p className=\"text-xs text-natural-olive font-mono mt-0.5\">Automatisches CO2-Minderungsverfahren</p>\n                      </div>\n                    </div>\n                    <span className=\"code text-[11px] bg-natural-sage px-2 py-1 rounded text-natural-olive font-semibold\">\n                      active_state\n                    </span>\n                  </header>\n\n                  <div className=\"space-y-6\">\n                    {/* Car km input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-natural-text flex items-center gap-1.5 font-sans\">\n                          Autonutzung (Benzin/Diesel Durchschnitt)\n                        </label>\n                        <span className=\"text-xs font-mono text-natural-olive bg-natural-sage/30 px-2 py-0.5 rounded\">\n                          {EMISSION_FACTORS.transport.car} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      \n                      <div className=\"flex mt-1 rounded-xl overflow-hidden border border-natural-border\">\n                        <input\n                          id=\"input-car-km\"\n                          type=\"number\"\n                          value={state.transport.carKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'carKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-3 bg-white focus:outline-hidden text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 bg-natural-sage/50 text-natural-olive text-xs font-mono border-l border-natural-border\">\n                          km\n                        </span>\n                      </div>\n                      \n                      {/* Metric info output and comparison bar */}\n                      <div className=\"space-y-2 mt-2\">\n                        <div className=\"flex justify-between items-center text-xs text-natural-text/70\">\n                          <span>Auto CO\342\202\202-\303\204quivalent</span>\n                          <span className=\"font-semibold text-natural-text font-mono\">\n                            {((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car).toFixed(2)} kg CO\342\202\202\n                          </span>\n                        </div>\n                        {/* Dynamic Progress Bar */}\n                        <div className=\"w-full h-1.5 bg-natural-sage rounded-full overflow-hidden\">\n                          <div \n                            className=\"h-full bg-natural-olive rounded-full transition-all duration-300\" \n                            style={{ \n                              width: `${Math.min(100, ((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car) * 4)}%` \n                            }}\n                          />\n                        </div>\n                      </div>\n                    </div>\n\n                    <div className=\"accent-border border-t border-dashed my-4\" />\n\n                    {/* Public transport km input */}\n                    <div className=\"space-y-2\">\n                      <div className=\"flex items-center justify-between\">\n                        <label className=\"text-sm font-semibold text-natural-text flex items-center gap-1.5 font-sans\">\n                          \303\226PNV-Nutzung (Kollektivverkehr / Bus & Bahn)\n                        </label>\n                        <span className=\"text-xs font-mono text-natural-olive bg-natural-sage/30 px-2 py-0.5 rounded\">\n                          {EMISSION_FACTORS.transport.publicTransport} kg CO\342\202\202 / km\n                        </span>\n                      </div>\n                      \n                      <div className=\"flex mt-1 rounded-xl overflow-hidden border border-natural-border\">\n                        <input\n                          id=\"input-public-km\"\n                          type=\"number\"\n                          value={state.transport.publicTransportKm || \'\'}\n                          onChange={(e) => updateValue(\'transport\', \'publicTransportKm\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-3 bg-white focus:outline-hidden text-sm\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 bg-natural-sage/50 text-natural-olive text-xs font-mono border-l border-natural-border\">\n                          km\n                        </span>\n                      </div>\n\n                      <div className=\"space-y-2 mt-2\">\n                        <div className=\"flex justify-between items-center text-xs text-natural-text/70\">\n                          <span>\303\226PNV CO\342\202\202-\303\204quivalent</span>\n                          <span className=\"font-semibold text-natural-text font-mono\">\n                            {((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport).toFixed(2)} kg CO\342\202\202\n                          </span>\n                        </div>\n                        {/* Dynamic Progress Bar for Transit */}\n                        <div className=\"w-full h-1.5 bg-natural-sage rounded-full overflow-hidden\">\n                          <div \n                            className=\"h-full bg-natural-sage-dark rounded-full transition-all duration-300\" \n                            style={{ \n                              width: `${Math.min(100, ((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport) * 4)}%` \n                            }}\n                          />\n                        </div>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 2. Category: Nutrition */}\n                <div className=\"card-natural p-6 flex flex-col justify-between hover:translate-y-[-1px] transition-all bg-white\">\n                  <header className=\"flex justify-between items-start mb-6 border-b border-natural-border/20 pb-4\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-natural-sage rounded-xl text-natural-olive\">\n                        <Leaf size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"serif text-2xl text-natural-text\">02. Nutrition & Diet</h2>\n                        <p className=\"text-xs text-natural-olive font-mono mt-0.5\">Tagesbilanzierung unterschiedlicher Ern\303\244hrungsstile</p>\n                      </div>\n                    </div>\n                    <span className=\"code text-[11px] bg-natural-sage px-2 py-1 rounded text-natural-olive font-semibold font-mono\">\n                      local_sync\n                    </span>\n                  </header>\n\n                  <div className=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n                    \n                    {/* Meat-rich days input card with Natural tone styling */}\n                    <div className=\"p-5 bg-amber-50/20 border border-[#d88c4b]/20 rounded-2xl space-y-3\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"text-[10px] uppercase font-bold tracking-wider text-[#d88c4b] flex items-center gap-1\">\n                          <Beef size={12} />\n                          Meat Based\n                        </span>\n                        <span className=\"text-xs font-mono text-[#d88c4b]\">{EMISSION_FACTORS.diet.meatRich} kg/Tag</span>\n                      </div>\n                      \n                      <div>\n                        <label className=\"text-xs text-natural-text/80 block mb-1\">Anzahl Tage (fleischreich)</label>\n                        <div className=\"flex rounded-lg overflow-hidden border border-natural-border bg-white\">\n                          <input\n                            id=\"input-meat-days\"\n                            type=\"number\"\n                            value={state.diet.meatRichDays || \'\'}\n                            onChange={(e) => updateValue(\'diet\', \'meatRichDays\', parseFloat(e.target.value))}\n                            placeholder=\"0\"\n                            className=\"flex-1 w-full px-3 py-2 text-sm focus:outline-hidden font-mono\"\n                            min=\"0\"\n                          />\n                          <span className=\"bg-slate-50 text-slate-500 text-xs px-3 flex items-center border-l border-natural-border\">\n                            Tage\n                          </span>\n                        </div>\n                      </div>\n\n                      <div className=\"text-xs text-slate-500 font-mono text-right pt-2 border-t border-amber-500/10\">\n                        = <span className=\"font-bold text-natural-text\">{((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich).toFixed(1)} kg CO\342\202\202</span>\n                      </div>\n                    </div>\n\n                    {/* Vegan days input card with Natural green styling */}\n                    <div className=\"p-5 bg-natural-sage/40 border border-natural-border rounded-2xl space-y-3\">\n                      <div className=\"flex items-center justify-between\">\n                        <span className=\"text-[10px] uppercase font-bold tracking-wider text-natural-olive flex items-center gap-1\">\n                          <Leaf size={12} />\n                          Vegan option\n                        </span>\n                        <span className=\"text-xs font-mono text-natural-olive\">{EMISSION_FACTORS.diet.vegan} kg/Tag</span>\n                      </div>\n\n                      <div>\n                        <label className=\"text-xs text-natural-text/80 block mb-1\">Anzahl Tage (vegan)</label>\n                        <div className=\"flex rounded-lg overflow-hidden border border-natural-border bg-white\">\n                          <input\n                            id=\"input-vegan-days\"\n                            type=\"number\"\n                            value={state.diet.veganDays || \'\'}\n                            onChange={(e) => updateValue(\'diet\', \'veganDays\', parseFloat(e.target.value))}\n                            placeholder=\"0\"\n                            className=\"flex-1 w-full px-3 py-2 text-sm focus:outline-hidden font-mono\"\n                            min=\"0\"\n                          />\n                          <span className=\"bg-slate-50 text-slate-500 text-xs px-3 flex items-center border-l border-natural-border\">\n                            Tage\n                          </span>\n                        </div>\n                      </div>\n\n                      <div className=\"text-xs text-slate-500 font-mono text-right pt-2 border-t border-natural-olive/10\">\n                        = <span className=\"font-bold text-natural-text\">{((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan).toFixed(1)} kg CO\342\202\202</span>\n                      </div>\n                    </div>\n\n                  </div>\n                </div>\n\n                {/* 3. Category: Energy Consumption */}\n                <div className=\"card-natural p-6 flex flex-col justify-between hover:translate-y-[-1px] transition-all bg-white\">\n                  <header className=\"flex justify-between items-start mb-6 border-b border-natural-border/20 pb-4\">\n                    <div className=\"flex items-center gap-3\">\n                      <div className=\"p-2 bg-natural-sage rounded-xl text-natural-olive\">\n                        <Zap size={20} />\n                      </div>\n                      <div>\n                        <h2 className=\"serif text-2xl text-natural-text\">03. Energy Consumption</h2>\n                        <p className=\"text-xs text-natural-olive font-mono mt-0.5\">Stromverbrauch auf Basis der aktuellen kWh-Menge</p>\n                      </div>\n                    </div>\n                    <span className=\"code text-[11px] bg-natural-sage px-2 py-1 rounded text-natural-olive font-semibold\">\n                      per_kwh_logic\n                    </span>\n                  </header>\n\n                  <div className=\"space-y-4\">\n                    <div className=\"flex items-end justify-between flex-wrap gap-2\">\n                      <div className=\"flex items-baseline gap-2\">\n                        <span className=\"text-5xl font-light serif text-natural-text\">420</span>\n                        <span className=\"text-sm italic text-natural-olive opacity-80\">g CO\342\202\202 / kWh</span>\n                      </div>\n                      <span className=\"text-xs font-mono text-natural-olive bg-natural-sage/35 px-2 py-1 rounded\">\n                        Faktor: {EMISSION_FACTORS.consumption.electricity} kg / kWh\n                      </span>\n                    </div>\n\n                    <div className=\"space-y-2 pt-2\">\n                      <label className=\"text-sm font-semibold text-natural-text block\">Stromz\303\244hlerstand / Gesamtverbrauch</label>\n                      <div className=\"flex rounded-xl overflow-hidden border border-natural-border bg-white shadow-xs\">\n                        <input\n                          id=\"input-electricity-kwh\"\n                          type=\"number\"\n                          value={state.consumption.electricityKWh || \'\'}\n                          onChange={(e) => updateValue(\'consumption\', \'electricityKWh\', parseFloat(e.target.value))}\n                          placeholder=\"0\"\n                          className=\"flex-1 w-full px-4 py-3 text-sm focus:outline-hidden\"\n                          min=\"0\"\n                        />\n                        <span className=\"inline-flex items-center px-4 bg-natural-sage/55 text-natural-olive text-xs font-mono border-l border-natural-border\">\n                          kWh\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center text-xs text-natural-text/75 mt-2 font-mono px-1\">\n                        <span>Konsumierte CO\342\202\202-Menge</span>\n                        <span className=\"font-bold\">\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg CO\342\202\202\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n                </div>\n\n              </div>\n\n              {/* Right Column: Calculations and Persistency Control panel */}\n              <div className=\"space-y-6\">\n                \n                {/* Visualizer / Output Panel Card */}\n                <div className=\"bg-[#2d2d2a] text-[#a8a89b] rounded-3xl p-6 border border-natural-border flex flex-col justify-between min-h-[440px] sticky top-28 shadow-xl\">\n                  <div>\n                    <span className=\"text-natural-sage-dark font-mono text-xs uppercase tracking-widest font-bold\">\n                      CO2 COMPUTATION UNIT\n                    </span>\n                    <h3 className=\"serif text-3xl font-light text-white italic mt-1.5\">Datenstrom & Bilanz</h3>\n                    \n                    <p className=\"text-xs text-slate-300 mt-2 leading-relaxed\">\n                      Lokaler State wird fortlaufend verarbeitet. Mathematische Formel: \n                      <code className=\"text-white bg-white/10 px-1 py-0.5 rounded font-mono text-[10px] ml-1\">\n                        calculateTotalCO2()\n                      </code>.\n                    </p>\n                    \n                    {/* Big Metric Display in Cormorant Garamond style */}\n                    <div className=\"my-8 py-6 border-y border-white/10 flex flex-col items-center\">\n                      <span className=\"text-xs uppercase tracking-wider text-slate-400 font-mono\">Gesamtmenge berechnet</span>\n                      <div className=\"flex items-baseline gap-2 mt-2\">\n                        <motion.span \n                          key={totalCO2}\n                          initial={{ scale: 0.94, opacity: 0.8 }}\n                          animate={{ scale: 1, opacity: 1 }}\n                          className=\"serif text-6xl font-light text-white italic\"\n                        >\n                          {totalCO2.toLocaleString(\'de-DE\', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}\n                        </motion.span>\n                        <span className=\"text-lg text-white font-serif italic\">kg</span>\n                      </div>\n                    </div>\n\n                    {/* Breakdown sub list */}\n                    <div className=\"space-y-2.5 mt-4 text-xs font-mono text-[#a8a89b]\">\n                      <div className=\"flex justify-between items-center bg-white/5 px-3 py-1.5 rounded-lg\">\n                        <span className=\"text-slate-400\">Transport:</span>\n                        <span className=\"text-white font-bold\">\n                          {(((state.transport.carKm || 0) * EMISSION_FACTORS.transport.car) +\n                            ((state.transport.publicTransportKm || 0) * EMISSION_FACTORS.transport.publicTransport)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center bg-white/5 px-3 py-1.5 rounded-lg\">\n                        <span className=\"text-slate-400\">Ern\303\244hrung:</span>\n                        <span className=\"text-white font-bold\">\n                          {(((state.diet.meatRichDays || 0) * EMISSION_FACTORS.diet.meatRich) + \n                            ((state.diet.veganDays || 0) * EMISSION_FACTORS.diet.vegan)).toFixed(2)} kg\n                        </span>\n                      </div>\n                      <div className=\"flex justify-between items-center bg-white/5 px-3 py-1.5 rounded-lg\">\n                        <span className=\"text-slate-400\">Konsum/Strom:</span>\n                        <span className=\"text-white font-bold\">\n                          {((state.consumption.electricityKWh || 0) * EMISSION_FACTORS.consumption.electricity).toFixed(2)} kg\n                        </span>\n                      </div>\n                    </div>\n                  </div>\n\n                  <div className=\"space-y-3 mt-8 pt-4 border-t border-white/5\">\n                    {/* Action buttons with .olive-btn style */}\n                    <button\n                      id=\"btn-manual-save\"\n                      onClick={handleSave}\n                      className=\"olive-btn w-full py-3 px-5 text-[#f5f5f0] bg-natural-olive hover:opacity-90 rounded-full font-semibold text-sm transition-all flex items-center justify-center gap-2 cursor-pointer shadow-md active:scale-[0.98]\"\n                    >\n                      {saveSuccess ? (\n                        <>\n                          <Check size={14} className=\"text-[#f5f5f0]\" />\n                          Erfolgreich gespeichert!\n                        </>\n                      ) : (\n                        <>\n                          <Save size={14} />\n                          Zustand manuell absichern\n                        </>\n                      )}\n                    </button>\n\n                    <button\n                      id=\"btn-reset\"\n                      onClick={handleReset}\n                      className=\"w-full py-2.5 px-4 bg-white/5 hover:bg-white/10 text-white border border-white/10 rounded-full font-medium text-xs transition-all flex items-center justify-center gap-1.5 cursor-pointer\"\n                    >\n                      <RefreshCw size={12} />\n                      Zustand zur\303\274cksetzen\n                    </button>\n                    \n                    <div className=\"flex justify-center items-center gap-1.5 text-[10px] text-slate-400 font-mono bg-black/20 py-2 rounded-lg\">\n                      <HardDrive size={11} />\n                      Wird bei \303\204nderungen automatisch gesichert\n                    </div>\n                  </div>\n\n                </div>\n\n              </div>\n\n            </motion.div>\n          ) : (\n            \n            /* Code View Tab displaying modular store.js logic cleanly in Natural Tones mockup frame */\n            <motion.div\n              key=\"code\"\n              initial={{ opacity: 0, y: 15 }}\n              animate={{ opacity: 1, y: 0 }}\n              exit={{ opacity: 0, y: -15 }}\n              transition={{ duration: 0.25 }}\n              className=\"bg-[#2d2d2a] text-[#a8a89b] rounded-3xl overflow-hidden border border-natural-border shadow-xl\"\n            >\n              {/* Browser mockup controls */}\n              <div className=\"bg-[#242422] text-[#8c8c6a] px-6 py-4 border-b border-[#3d3d3a] flex items-center justify-between\">\n                <div className=\"flex items-center gap-2\">\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-red-400/80\" />\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-yellow-400/80\" />\n                  <div className=\"w-2.5 h-2.5 rounded-full bg-green-400/80\" />\n                  <span className=\"code text-xs ml-4 text-white font-medium italic opacity-95\">/src/store.js \342\200\224 ES6 Modular State</span>\n                </div>\n                \n                <button\n                  id=\"btn-copy-code\"\n                  onClick={copyToClipboard}\n                  className=\"px-4 py-1.5 bg-neutral-800 hover:bg-neutral-700 text-white text-xs font-semibold rounded-full border border-neutral-700 transition-all flex items-center gap-1.5 cursor-pointer\"\n                >\n                  {copied ? (\n                    <>\n                      <Check size={12} className=\"text-[#8c8c6a]\" />\n                      Code kopiert!\n                    </>\n                  ) : (\n                    <>\n                      Code kopieren\n                    </>\n                  )}\n                </button>\n              </div>\n              \n              <div className=\"p-6 overflow-x-auto text-[13px] code leading-relaxed bg-[#2d2d2a] text-[#a8a89b] shadow-inner select-all\">\n                <pre>{storeCode}</pre>\n              </div>\n\n              {/* Persistence module tag explanation below */}\n              <div className=\"bg-[#3d3d3a] p-6 border-t border-[#4d4d4a] rounded-b-3xl text-sm space-y-3\">\n                <p className=\"text-[10px] uppercase tracking-widest font-bold text-[#8c8c6a] mb-1\">Persistence Module & Speicherung</p>\n                <pre className=\"code text-xs text-[#8c8c6a] bg-black/20 p-3 rounded-lg overflow-x-auto\">\n                  localStorage.setItem(\'co2_calculator_state\', JSON.stringify(state));\n                </pre>\n                \n                <div className=\"pt-2\">\n                  <h4 className=\"font-bold text-white flex items-center gap-1.5 serif italic text-lg\">\n                    <Sparkles size={16} className=\"text-[#8c8c6a]\" />\n                    Architekturmerkmale dieser L\303\266sung:\n                  </h4>\n                  <ul className=\"list-disc pl-5 mt-2 space-y-1 text-slate-300 text-xs\">\n                    <li><strong>Saubere Separation of Concerns</strong>: Die gesamte Kalkulationslogik liegt losgel\303\266st von irgendwelchem Markup oder Styling in <code className=\"bg-black/30 text-white px-1 py-0.5 rounded font-mono text-xs\">store.js</code>.</li>\n                    <li><strong>Deep Clone Safety</strong>: Beim Laden/Standardisieren wird mit <code className=\"bg-black/30 text-white px-1.5 py-0.5 rounded font-mono text-xs\">JSON.parse(JSON.stringify())</code> gearbeitet, um versehentliche Mutationen von <code className=\"bg-black/30 text-white px-1.5 py-0.5 rounded font-mono text-xs\">INITIAL_STATE</code> zu verhindern.</li>\n                    <li><strong>Eingabe-Ausfallsicherheit</strong>: Das Modell f\303\244ngt fehlerhafte/unvollst\303\244ndige Typen im <code className=\"bg-black/30 text-white px-1.5 py-0.5 rounded font-mono text-xs\">localStorage</code> automatisch ab und synchronisiert die Struktur.</li>\n                  </ul>\n                </div>\n              </div>\n            </motion.div>\n          )}\n        </AnimatePresence>\n\n      </main>\n\n      {/* Light Clean Footer */}\n      <footer className=\"bg-white/40 border-t border-natural-border/30 py-8 px-6 text-center text-[11px] uppercase tracking-wider text-natural-olive/60 mt-auto font-mono\">\n        <p>Designed for Clean Integration \302\267 \302\251 2026 CO2-Architecture ESM System.</p>\n      </footer>\n    </div>\n  );"
      }
      num_matches: 1
    }
  }
}
